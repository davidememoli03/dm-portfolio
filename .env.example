# =============================================================================
# Required for Docker Compose (prod + dev)
# =============================================================================

# Postgres credentials. Same values are read by the db service and the backend.
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=portfolio

# JWT signing secret. Use a long random string (>= 32 chars). REQUIRED in prod.
JWT_SECRET=please-change-me-to-a-long-random-string

# Single admin account. Username is plain; password is the bcrypt hash.
# Generate with:  npm run server:hash-password -- 'your-password'
# (On exFAT/external drives run `npm run server:install` first — it uses --no-bin-links.)
# Dev default below = password "admin". Remove or replace in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$$2b$$10$$JVkYGsubuszwDLz7LWaPGOM9dnEgFurFHd2/NJNMCt4MV3YoJp5K.

# Public URL of the admin app (included in notification emails).
ADMIN_URL=http://localhost:4201

# Contact endpoint rate limit per IP per hour. Defaults to 5.
CONTACT_RATE_LIMIT_PER_HOUR=5

# =============================================================================
# Optional - SMTP notifications
# =============================================================================
# Leave empty to disable email notifications when a new message arrives.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_TO=
